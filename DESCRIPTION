Package: STMotif
Type: Package
Title: Discovery of Motifs in Spatial-Time Series
Version: 2.0.3
Authors@R: c(
    person("Heraldo", "Borges", email = "stmotif@eic.cefet-rj.br", role = c("aut", "cre"), comment = "CEFET/RJ"),
    person("Amin", "Bazaz", role = c("aut"), comment = "Polytech'Montpellier"),
